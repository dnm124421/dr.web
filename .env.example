# Server Port
PORT=3000

# Gmail SMTP Configuration
# 1. Go to Google Account Settings -> Security -> 2-Step Verification -> App Passwords
# 2. Generate a new App Password (e.g. name it "Doctor Website")
# 3. Enter your Gmail address in SMTP_USER and the 16-character code in SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password
